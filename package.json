    "structured-output",
    "human-in-the-loop",
    "typescript"
  ],
  "license": "Apache-2.0",
  "author": "Abhishek Chauhan",
  "repository": {
    "type": "git",
    "url": "https://github.com/ac12644/langgraph-starter-kit"
  },
  "scripts": {
