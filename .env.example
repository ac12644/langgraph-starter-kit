# LLM Provider: openai | anthropic | google | groq | ollama
LLM_PROVIDER=openai

# API keys (only the one matching your provider is required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Model override (optional — sensible defaults per provider)
# LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0

# Server
PORT=3000

# MCP servers config (optional)
# MCP_SERVERS_PATH=./mcp-servers.json

# LangSmith tracing (optional)
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=langgraph-starter-kit
# LANGCHAIN_TRACING_V2=true

# Production persistence (optional)
# Install: npm install @langchain/langgraph-checkpoint-postgres
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/langgraph
